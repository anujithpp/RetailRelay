# --- Dependencies ---
node_modules/  # Frontend and backend dependencies

# --- Environment Variables (SECURITY!) ---
.env
.env.local
.env.development
.env.production
.env.test

# --- Build Outputs ---
build/         # React production build
dist/          # Node.js compiled output (if using TypeScript)
.out/
.next/

# --- Database Local Files ---
/data/         # PostgreSQL data directory (if stored locally)
/pgdata/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE/Editor ---
.idea/         # WebStorm/JetBrains
.vscode/       # VS Code
*.iml
*.suo
*.swp          # Vim temporary files

# --- OS Junk Files ---
.DS_Store      # macOS
Thumbs.db      # Windows
desktop.ini

# --- Testing/Coverage ---
coverage/
.nyc_output/

# --- Node.js Temporary Files ---
.npm/
.yarn/
.tmp/